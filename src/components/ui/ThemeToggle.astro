---
/* Client-side theme toggle. The initial theme is already applied via the
   inline bootstrap script in BaseLayout, so this component only handles
   the user interaction and persists the choice in localStorage. */
---

<button
  type="button"
  id="theme-toggle"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-line text-ink-muted transition hover:border-brand hover:text-ink focus-visible:ring-brand"
  aria-label="Erscheinungsbild wechseln"
  title="Erscheinungsbild wechseln"
>
  <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79Z" />
  </svg>
</button>

<script>
  /* Toggle only flips the current session's theme; nothing is persisted.
     Every fresh page load starts in light mode — see BaseLayout bootstrap. */
  const toggle = document.getElementById("theme-toggle");
  if (toggle) {
    toggle.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle("dark");
      root.dataset.theme = isDark ? "dark" : "light";
    });
  }
</script>
