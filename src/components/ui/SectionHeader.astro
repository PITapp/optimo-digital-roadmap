---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "start" | "center";
}

const { eyebrow, title, lede, align = "start" } = Astro.props;
---

<header
  class:list={[
    "max-w-3xl",
    align === "center" && "mx-auto text-center",
  ]}
>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="text-display-lg font-semibold text-ink">{title}</h2>
  {lede && <p class="lede mt-4">{lede}</p>}
</header>
