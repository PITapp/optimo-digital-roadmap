---
import ThemeToggle from "@components/ui/ThemeToggle.astro";

type NavItem = {
  href: string;
  label: string;
  muted?: boolean;
};

/* Anker beginnen mit "/#…", damit sie sowohl auf der Startseite (interner
   Sprung) als auch auf der Unterseite "Technischer Hintergrund"
   (vollständige Navigation) korrekt funktionieren. */
const navItems: NavItem[] = [
  { href: "/#summary", label: "Überblick" },
  { href: "/#bc-migration", label: "Migration" },
  { href: "/#scanner-app", label: "Scanner" },
  { href: "/#aussendienst", label: "Außendienst" },
  { href: "/#versand", label: "Versand" },
  { href: "/#etiketten", label: "Etiketten" },
  { href: "/#roadmap", label: "Roadmap" },
  { href: "/technischer-hintergrund/", label: "Hintergrund", muted: true },
  { href: "/#contact", label: "Kontakt" },
];
---

<header
  class="sticky top-0 z-40 border-b border-line/60 bg-surface/85 backdrop-blur supports-[backdrop-filter]:bg-surface/70"
>
  <div class="container-content flex h-16 items-center justify-between gap-4">
    <a
      href="/"
      title="Optimo Business Central Roadmap — präsentiert von PITapp"
      class="flex shrink-0 items-center"
    >
      <span class="inline-flex items-center rounded dark:bg-white dark:px-2 dark:py-1">
        <img
          src="/optimo-logo.png"
          alt="Optimo Schlafsysteme"
          width="242"
          height="80"
          class="h-9 w-auto"
          loading="eager"
          decoding="async"
        />
      </span>
    </a>

    <nav aria-label="Hauptnavigation" class="hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "whitespace-nowrap rounded-md px-3 py-2 text-sm transition hover:bg-surface-muted hover:text-ink",
              item.muted ? "text-ink-subtle" : "text-ink-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <a
        href="/logout.php"
        title="Abmelden"
        class="rounded-md px-3 py-2 text-sm text-ink-subtle transition hover:bg-surface-muted hover:text-ink"
      >
        Abmelden
      </a>
    </div>
  </div>
</header>
