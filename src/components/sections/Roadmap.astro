---
import { getEntry, render } from "astro:content";
import Section from "@components/ui/Section.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";

const entry = await getEntry("sections", "roadmap");
const { Content } = await render(entry!);
const { eyebrow, title, lede } = entry!.data;

const steps = [
  {
    step: "01",
    title: "Fundament",
    pillar: "Business-Central-Migration",
    description:
      "Die neue BC-Version als technisches Rückgrat. Moderne Schnittstellen, längere Wartungszusage, bessere Oberfläche — Voraussetzung für die vier Apps.",
  },
  {
    step: "02",
    title: "Lager",
    pillar: "Scanner-App",
    description:
      "Inventur, Umlagerungen, Artikelinformationen und die LKW-Beladung im Versand — als moderne Web-App statt proprietärem Scanner-Client.",
  },
  {
    step: "03",
    title: "Kundenfront",
    pillar: "Außendienst-App",
    description:
      "Eigenständige PITapp-App auf Laptop oder Tablet, offline-fähig, mit BC-Anbindung — konsequent auf den Verkauf zugeschnitten.",
  },
  {
    step: "04",
    title: "Auslieferung",
    pillar: "Versand- & Auslieferungs-App",
    description:
      "Die digitale Brücke zwischen Fahrer und Zentrale: Tourenbegleiter, Liefernachweis und Kommunikation in einer offline-fähigen App.",
  },
  {
    step: "05",
    title: "Markenauftritt",
    pillar: "Etiketten- & Markenkennzeichnungs-App",
    description:
      "Pflicht-Ersatz für das Etikettentool aus Navision 5 — kann parallel zur BC-Migration laufen. Parametergesteuerte Produktetiketten für Matratzen und Lattenroste.",
  },
];
---

<Section id="roadmap" variant="muted">
  <SectionHeader eyebrow={eyebrow} title={title} lede={lede} />

  <div class="prose prose-neutral dark:prose-invert mt-10 max-w-3xl text-ink-muted prose-p:text-ink-muted">
    <Content />
  </div>

  <ol class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
    {
      steps.map((item, idx) => (
        <li class="relative rounded-xl border border-line/70 bg-surface-alt p-6 shadow-card dark:shadow-card-dark">
          <span class:list={["text-xs font-semibold uppercase tracking-[0.18em]", idx === 0 ? "text-accent" : "text-brand"]}>
            {item.step} · {item.pillar}
          </span>
          <h3 class="mt-3 text-xl font-semibold text-ink">{item.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-ink-muted">
            {item.description}
          </p>
        </li>
      ))
    }
  </ol>

  <p class="mt-10 max-w-2xl text-sm text-ink-subtle">
    Die Reihenfolge ist ein Vorschlag — jede Säule ist einzeln bestellbar.
    Als Paket entfaltet sich der größte Nutzen.
  </p>
</Section>
