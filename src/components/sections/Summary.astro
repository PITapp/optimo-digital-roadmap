---
import { getEntry, render } from "astro:content";
import Section from "@components/ui/Section.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";

const entry = await getEntry("sections", "summary");
const { Content } = await render(entry!);
const { eyebrow, title, lede } = entry!.data;
---

<Section id="summary" variant="muted">
  <SectionHeader eyebrow={eyebrow} title={title} lede={lede} />

  <div class="prose prose-neutral dark:prose-invert mt-10 max-w-3xl text-ink-muted prose-p:text-ink-muted prose-strong:text-ink">
    <Content />
  </div>

  <div class="mt-14 grid gap-6 md:grid-cols-3">
    <div class="rounded-lg border border-line/70 bg-surface-alt p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Was</p>
      <p class="mt-3 text-sm text-ink-muted">
        Fünf konkrete Modernisierungs-Angebote — einzeln sinnvoll,
        gemeinsam wirkungsvoller.
      </p>
    </div>
    <div class="rounded-lg border border-line/70 bg-surface-alt p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Warum jetzt</p>
      <p class="mt-3 text-sm text-ink-muted">
        Technische Schuld an mehreren Stellen: Business Central
        Version 14, veraltete Scanner-Lösung, 20 Jahre alte
        Außendienst-Software, papier- und telefongetriebene Auslieferung,
        Etikettentool in Navision 5 ohne Migrationspfad.
      </p>
    </div>
    <div class="rounded-lg border border-line/70 bg-surface-alt p-6">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">Warum PITapp</p>
      <p class="mt-3 text-sm text-ink-muted">
        Ein vertrauter Partner für alle fünf Themen — statt
        mehrerer verschiedener Dienstleister.
      </p>
    </div>
  </div>
</Section>
