---
/* Dezenter Einstiegspunkt von der Hauptpräsentation in den Bereich
   "Technischer Hintergrund". Bewusst zurückhaltend: in Tech-Slate, mit
   Outline-CTA, kein gefüllter Brand-Button — soll nicht mit den
   fachlichen Hauptsektionen konkurrieren. */
---

<section
  aria-labelledby="tech-link-heading"
  class="border-y border-line/60 bg-surface"
>
  <div class="container-content py-10 md:py-14">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-tech mb-3">
          Für technisch Interessierte
        </p>
        <h2 id="tech-link-heading" class="text-display-md font-semibold text-ink">
          Ein Blick hinter die Kulissen
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-ink-muted md:text-base">
          Wie die vier Apps aufgebaut sind, wie sie mit Business Central
          zusammenspielen und welche Technologien zum Einsatz kommen — auf
          einer eigenen, vertiefenden Seite zusammengefasst. Ein optionales
          Angebot für IT-Verantwortliche und technisch interessierte Leser.
        </p>
      </div>
      <a
        href="/technischer-hintergrund/"
        class="inline-flex shrink-0 items-center gap-2 self-start rounded-md border border-line px-5 py-3 text-sm font-medium text-ink-muted transition hover:border-tech hover:text-ink md:self-auto"
      >
        Technischer Hintergrund
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
