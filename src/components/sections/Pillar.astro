---
import type { CollectionEntry } from "astro:content";
import Section from "@components/ui/Section.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import Card from "@components/ui/Card.astro";

interface Props {
  entry: CollectionEntry<"pillars">;
  variant?: "default" | "muted" | "alt";
}

const { entry, variant = "default" } = Astro.props;
const { eyebrow, title, lede, anchor, situation, features, keyMessage, gallery, galleryLayout = "screens" } = entry.data;

const galleryClasses =
  galleryLayout === "phones"
    ? {
        grid: "mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3",
        frame: "mx-auto max-w-[260px] aspect-[9/16]",
      }
    : {
        grid: "mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3",
        frame: "aspect-[3/2]",
      };
---

<Section id={anchor} variant={variant}>
  <SectionHeader eyebrow={eyebrow} title={title} lede={lede} />

  <div class="mt-12 grid gap-10 lg:grid-cols-[minmax(0,2fr)_minmax(0,3fr)]">
    <div class="space-y-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-subtle">
          Ausgangssituation
        </p>
        <p class="mt-3 text-sm leading-relaxed text-ink-muted md:text-base">
          {situation}
        </p>
      </div>

      <div class="rounded-lg border-l-2 border-brand bg-surface-muted/60 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-brand">
          Kernbotschaft
        </p>
        <p class="mt-2 text-sm leading-relaxed text-ink md:text-base">
          {keyMessage}
        </p>
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-subtle">
        Funktionen
      </p>

      <ul class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          features.map((feature) => (
            <li>
              <Card class="h-full">
                <p class="text-sm font-semibold text-ink">{feature.title}</p>
                <p class="mt-2 text-sm leading-relaxed text-ink-muted">
                  {feature.description}
                </p>
              </Card>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  {
    gallery && gallery.length > 0 && (
      <div class="mt-16">
        <div class="flex items-baseline justify-between gap-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-subtle">
            Muster-Vorschau
          </p>
          <p class="text-xs text-ink-subtle">
            Stilisierte Platzhalter — finale Screenshots werden nachgereicht.
          </p>
        </div>

        <ul class={galleryClasses.grid}>
          {gallery.map((item) => (
            <li>
              <figure class="flex h-full flex-col">
                <div class={`overflow-hidden rounded-xl border border-line/70 bg-surface-alt shadow-card dark:shadow-card-dark ${galleryClasses.frame}`}>
                  <img
                    src={item.src}
                    alt={item.alt}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-contain"
                  />
                </div>
                <figcaption class="mt-3 text-sm leading-relaxed text-ink-muted">
                  {item.caption}
                </figcaption>
              </figure>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</Section>
